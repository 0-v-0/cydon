{
	"compilerOptions": {
		"lib": [
			"es2022",
			"dom"
		],
		"allowJs": false,
		"declaration": true,
		"emitDeclarationOnly": true,
		"isolatedModules": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"moduleResolution": "bundler",
		"experimentalDecorators": true,
		"target": "es2022",
		"useDefineForClassFields": true,
		"skipLibCheck": true
	},
	"exclude": [
		"dist",
		"node_modules"
	]
}